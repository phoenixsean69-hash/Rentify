{
  "expo": {
    "name": "Rentify",
    "slug": "Rentify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rentify",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/onboarding.png",
        "backgroundImage": "./assets/images/onboarding.png",
        "monochromeImage": "./assets/images/onboarding.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.shon1123.Rentify"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E6F4FE",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a12dd98b-3705-46b8-80a1-7a93d248c911"
      }
    },
    "owner": "shon1123"
  }
}
